<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.llm-gateway</string>
    <!-- Note: macOS TCC blocks launchd from executing programs under ~/Documents, ~/Desktop, ~/Downloads
         place the repo elsewhere (e.g. ~/llm-gateway) and update the paths accordingly. -->
    <key>ProgramArguments</key>
    <array>
        <string>/Users/YOUR_NAME/llm-gateway/contrib/macos/run_gateway.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/YOUR_NAME/llm-gateway/data/gateway.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/YOUR_NAME/llm-gateway/data/gateway.err.log</string>
    <key>WorkingDirectory</key>
    <string>/Users/YOUR_NAME/llm-gateway</string>
</dict>
</plist>
